<<knit-theme>>=
## This is a test of knit_theme.css
f <- function(a = 0, b = 0) {
  if (a < b) {
    x <- mean(c(a, b), na.rm = FALSE)
  } else if (a > b) {
    x <- a + b
  } else {
    x <- "a = b"
  }
  x
}
f(a = 1, b = 2)

warning("Warning color not controlled by knit_theme.css ...")
stop("Error color not controlled by knit_theme.css ...")
@

